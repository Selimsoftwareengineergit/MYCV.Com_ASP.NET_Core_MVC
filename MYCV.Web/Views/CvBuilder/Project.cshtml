@using MYCV.Domain.Enums
@model List<MYCV.Application.DTOs.UserProjectDto>

@{
    ViewData["Title"] = "Projects";
    var currentStep = (int)CvStep.Projects;
    var completedSteps = new List<int> { (int)CvStep.WorkExperience };
}

<section class="py-5 bg-light">
    <div class="container">

        <div class="row mb-4">
            <div class="col text-center">
                <h2 class="fw-bold">Projects</h2>
                <p class="text-muted">Add your professional or personal projects</p>
            </div>
        </div>

        <div class="row">

            <!-- LEFT STEP NAVIGATION -->
            <div class="col-lg-4 mb-4">
                @await Component.InvokeAsync("CvStepNavigation", new
                    {
                        currentStep = currentStep,
                        completedSteps = completedSteps
                    })
            </div>

            <!-- RIGHT CONTENT -->
            <div class="col-lg-8" style="max-height:80vh; overflow-y:auto;">

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-semibold mb-0">Step <span id="currentStepDisplay">@currentStep</span></h4>
                            <span class="badge bg-primary">In Progress</span>
                        </div>

                        <div class="accordion" id="projectAccordion">
                            <!-- Initial Project Item -->
                            <div class="accordion-item step-form" data-step="@currentStep">
                                <h2 class="accordion-header position-relative">
                                    <button class="accordion-button" type="button" data-bs-toggle="collapse"
                                            data-bs-target="#collapseProject1">
                                        Project Information
                                    </button>
                                    <button type="button" class="btn-close position-absolute top-0 end-0 m-2 btn-remove-project"
                                            aria-label="Remove"></button>
                                </h2>

                                <div id="collapseProject1" class="accordion-collapse collapse show">
                                    <div class="accordion-body">
                                        <div class="row g-3">

                                            <div class="col-md-6">
                                                <label class="form-label required">Project Title</label>
                                                <input type="text" class="form-control projectTitle" placeholder="Enter project title" required />
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label required">Role</label>
                                                <input type="text" class="form-control role" placeholder="Your role in project" required />
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label required">Project Type</label>
                                                <select class="form-select projectType" required>
                                                    <option value="">Select type...</option>
                                                    @foreach (var type in Enum.GetValues(typeof(ProjectType)))
                                                    {
                                                        <option value="@type">@type</option>
                                                    }
                                                </select>
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Start Date</label>
                                                <input type="date" class="form-control startDate" required />
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">End Date</label>
                                                <input type="date" class="form-control endDate" />
                                            </div>

                                            <div class="col-md-6">
                                                <div class="form-check mt-2">
                                                    <input class="form-check-input isOngoing" type="checkbox">
                                                    <label class="form-check-label">Ongoing Project</label>
                                                </div>
                                            </div>

                                            <div class="col-md-12">
                                                <label class="form-label">Description</label>
                                                <textarea class="form-control description" rows="2" placeholder="Project details"></textarea>
                                            </div>

                                            <div class="col-md-12">
                                                <label class="form-label">Technologies</label>
                                                <input type="text" class="form-control technologies" placeholder="Used technologies" />
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Project Link</label>
                                                <input type="url" class="form-control projectLink" placeholder="https://..." />
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Priority</label>
                                                <input type="number" class="form-control priority" value="1" min="1" />
                                            </div>

                                            <div class="col-md-12">
                                                <label class="form-label">Remarks</label>
                                                <textarea class="form-control remarks" rows="2"></textarea>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- BUTTONS -->
                        <div class="d-flex justify-content-between mt-4">
                            <button type="button" class="btn btn-outline-secondary btn-prev-step">← Previous</button>
                            <button type="button" class="btn btn-success btn-add-project">+ Add Project</button>
                            <button type="button" class="btn btn-primary btn-next-step">Save & Continue →</button>
                        </div>

                    </div>
                </div>

            </div>

        </div>
    </div>
</section>

<!-- Info Modal -->
<div class="modal fade" id="infoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="infoModalTitle">Info</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="savedInfoContent">...</div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* CV Steps Styles (Same as Education) */
        .cv-steps {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .cv-steps .step {
                display: flex;
                align-items: center;
                position: relative;
                padding: 12px 0;
                color: #6c757d;
                font-weight: 500;
                cursor: pointer;
                transition: 0.3s;
            }

                .cv-steps .step .step-circle {
                    width: 28px;
                    height: 28px;
                    border-radius: 50%;
                    border: 2px solid #dee2e6;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    margin-right: 12px;
                    font-size: 14px;
                    transition: 0.3s;
                }

                .cv-steps .step.active {
                    color: #0d6efd;
                    font-weight: 600;
                }

                    .cv-steps .step.active .step-circle {
                        border-color: #0d6efd;
                        background-color: #0d6efd;
                        color: #fff;
                    }

                .cv-steps .step.completed {
                    color: #198754;
                }

                    .cv-steps .step.completed .step-circle {
                        border-color: #198754;
                        background-color: #198754;
                        color: #fff;
                    }

                .cv-steps .step:not(:last-child)::after {
                    content: '';
                    position: absolute;
                    left: 14px;
                    top: 42px;
                    height: 100%;
                    width: 2px;
                    background-color: #e9ecef;
                }

        /* Accordion Styles */
        .accordion-button {
            font-weight: bold;
            background-color: #e7f1ff;
            color: #0d6efd;
        }

            .accordion-button:not(.collapsed) {
                background-color: #cfe2ff;
                color: #0d6efd;
            }

        /* Required label asterisk */
        label.required::after {
            content: " *";
            color: red;
            font-weight: bold;
        }

        .accordion-header {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding-right: 2.5rem; /* space for the remove button */
            border: 1px solid #dee2e6;
            border-radius: 0.25rem;
            background-color: #e7f1ff;
        }

            .accordion-header .btn-remove-project {
                position: absolute;
                right: 8px;
                top: 50%;
                transform: translateY(-50%);
                width: 1.4rem;
                height: 1.4rem;
                padding: 0;
                font-size: 0.9rem;
                line-height: 1;
                border-radius: 50%;
                border: none;
                background-color: #dc3545;
                color: #fff;
                cursor: pointer;
                z-index: 1050;
                display: flex;
                align-items: center;
                justify-content: center;
            }

                .accordion-header .btn-remove-project:hover {
                    background-color: #b02a37;
                }

        /* Optional: make accordion body scrollable if many items */
        .accordion-body {
            max-height: 70vh;
            overflow-y: auto;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const accordion = document.getElementById('projectAccordion');

            const ProjectTypeList = @Html.Raw(Json.Serialize(Enum.GetValues(typeof(ProjectType))));

            // Add Project
            document.querySelector('.btn-add-project').addEventListener('click', function() {
                const count = accordion.querySelectorAll('.accordion-item').length + 1;
                const newItem = document.createElement('div');
                newItem.classList.add('accordion-item', 'step-form');
                newItem.setAttribute('data-step', '@currentStep');

                newItem.innerHTML = `
                    <h2 class="accordion-header position-relative">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseProject${count}">
                            Project ${count}
                        </button>
                        <button type="button" class="btn-close btn-remove-project" aria-label="Remove"></button>
                    </h2>
                    <div id="collapseProject${count}" class="accordion-collapse collapse">
                        <div class="accordion-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label required">Project Title</label>
                                    <input type="text" class="form-control projectTitle" placeholder="Enter project title" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label required">Role</label>
                                    <input type="text" class="form-control role" placeholder="Your role in the project" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label required">Project Type</label>
                                    <select class="form-select projectType" required>
                                        <option value="">Select type...</option>
                                        ${ProjectTypeList.map(t => `<option value="${t}">${t}</option>`).join('')}
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Start Date</label>
                                    <input type="date" class="form-control startDate" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">End Date</label>
                                    <input type="date" class="form-control endDate" />
                                </div>
                                <div class="col-md-12">
                                    <div class="form-check mt-2">
                                        <input class="form-check-input isOngoing" type="checkbox">
                                        <label class="form-check-label">Ongoing Project</label>
                                    </div>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label">Description</label>
                                    <textarea class="form-control description" rows="2"></textarea>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label">Technologies</label>
                                    <input type="text" class="form-control technologies" placeholder="Comma-separated technologies" />
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label">Project Link</label>
                                    <input type="text" class="form-control projectLink" placeholder="Optional project link" />
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label">Remarks</label>
                                    <textarea class="form-control remarks" rows="2"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
                accordion.appendChild(newItem);
            });

            // Remove Project
            accordion.addEventListener('click', function(e){
                if(e.target.classList.contains('btn-remove-project')){
                    const item = e.target.closest('.accordion-item');
                    if(item) {
                        item.remove();
                        updateProjectNumbers();
                    }
                }
            });

            // Update project numbering
            function updateProjectNumbers() {
                accordion.querySelectorAll('.accordion-item').forEach((item, index) => {
                    const btn = item.querySelector('.accordion-button');
                    btn.textContent = `Project ${index + 1}`;
                    const collapseDiv = item.querySelector('.accordion-collapse');
                    collapseDiv.id = `collapseProject${index + 1}`;
                    btn.dataset.bsTarget = `#collapseProject${index + 1}`;
                });
            }

            // Save Projects
            async function saveProjects(){
                const projectList = Array.from(accordion.querySelectorAll('.accordion-item')).map(item => ({
                    ProjectTitle: item.querySelector('.projectTitle').value,
                    Role: item.querySelector('.role').value,
                    ProjectType: item.querySelector('.projectType').value,
                    StartDate: item.querySelector('.startDate').value,
                    EndDate: item.querySelector('.endDate').value || null,
                    Description: item.querySelector('.description').value,
                    Technologies: item.querySelector('.technologies').value,
                    ProjectLink: item.querySelector('.projectLink').value,
                    Remarks: item.querySelector('.remarks').value
                }));

                try {
                    const response = await fetch('/CvBuilder/SaveProject', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(projectList)
                    });

                    const result = await response.json();
                    if(!result.success){ showModal("Error", result.message, "danger"); return; }

                    showModal("Success", formatSavedData(result.data), "success");

                    // Reset form after save
                    accordion.innerHTML = '';
                    document.querySelector('.btn-add-project').click(); // Add initial empty item

                } catch(err){
                    showModal("Error", "Failed to save projects", "danger");
                }
            }

            function formatSavedData(savedData){
                if(!savedData) return "No data saved.";
                let content = "<ul class='list-group'>";
                savedData.forEach((proj, index) => {
                    content += `<li class='list-group-item'><strong>${index+1}.</strong> ${proj.ProjectTitle} - ${proj.Role}</li>`;
                });
                content += "</ul>";
                return content;
            }

            // Modal
            function showModal(title, message, type="info"){
                const modalEl = document.getElementById('infoModal');
                document.getElementById('infoModalTitle').textContent = title;
                document.getElementById('savedInfoContent').innerHTML = message;

                const header = modalEl.querySelector('.modal-header');
                header.className = "modal-header";
                if(type === "success") header.classList.add("bg-success","text-white");
                else if(type === "danger") header.classList.add("bg-danger","text-white");
                else header.classList.add("bg-info","text-white");

                const modal = new bootstrap.Modal(modalEl);
                modal.show();
                setTimeout(()=> modal.hide(), 4000);
            }

            // Next & Previous
            document.querySelector('.btn-next-step').addEventListener('click', function(e){ e.preventDefault(); saveProjects(); });
            document.querySelector('.btn-prev-step').addEventListener('click', function(){ window.location.href = '/CvBuilder/Step?stepNumber=' + @((int)CvStep.Skills); });

        });
    </script>
}
