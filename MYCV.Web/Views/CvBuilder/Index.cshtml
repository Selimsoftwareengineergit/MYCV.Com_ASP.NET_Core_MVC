@using MYCV.Domain.Enums
@model MYCV.Application.DTOs.UserPersonalDetailDto

@{
    ViewData["Title"] = "CV Builder Dashboard";
}

<section class="py-5 bg-light">
    <div class="container">
        <div class="row mb-4">
            <div class="col text-center">
                <h2 class="fw-bold">Build Your CV</h2>
                <p class="text-muted">Complete each step to create your professional resume</p>
            </div>
        </div>

        <div class="row">
            <!-- LEFT STEP NAVIGATION -->
            <div class="col-lg-4 mb-4">
                @await Component.InvokeAsync("CvStepNavigation", new
                    {
                        currentStep = 1,
                        completedSteps = new List<int>()
                    })
            </div>

            <!-- RIGHT CONTENT AREA -->
            <div class="col-lg-8" style="max-height: 80vh; overflow-y: auto;">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-semibold mb-0">Step <span id="currentStepDisplay">1</span></h4>
                            <span class="badge bg-primary" id="stepBadge">In Progress</span>
                        </div>

                        <div class="accordion" id="cvFormAccordion">

                            <!-- Step 1: Personal Information -->
                            <div class="accordion-item step-form" data-step="1">
                                <h2 class="accordion-header" id="headingStep1">
                                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseStep1" aria-expanded="true" aria-controls="collapseStep1">
                                        Personal Information
                                    </button>
                                </h2>
                                <div id="collapseStep1" class="accordion-collapse collapse show" aria-labelledby="headingStep1">
                                    <div class="accordion-body">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label asp-for="FullName" class="form-label required">Full Name</label>
                                                <input asp-for="FullName" class="form-control" placeholder="Enter your full name" required aria-required="true" />
                                            </div>
                                            <div class="col-md-6">
                                                <label asp-for="ProfessionalTitle" class="form-label required">Professional Title</label>
                                                <input asp-for="ProfessionalTitle" class="form-control" placeholder="Software Engineer, Graphic Designer, etc." required aria-required="true" />
                                            </div>
                                            <div class="col-md-6">
                                                <label asp-for="DateOfBirth" class="form-label required">Date of Birth</label>
                                                <input asp-for="DateOfBirth" type="date" class="form-control" required aria-required="true" />
                                            </div>
                                            <div class="col-md-6">
                                                <label asp-for="Gender" class="form-label">Gender</label>
                                                <select asp-for="Gender" class="form-select" asp-items="Html.GetEnumSelectList<Gender>()">
                                                    <option value="">Choose...</option>
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label asp-for="Religion" class="form-label">Religion</label>
                                                <select asp-for="Religion" class="form-select" asp-items="Html.GetEnumSelectList<Religion>()">
                                                    <option value="">Choose...</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Step 2: Contact & Address -->
                            <div class="accordion-item step-form" data-step="2">
                                <h2 class="accordion-header" id="headingStep2">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseStep2" aria-expanded="false" aria-controls="collapseStep2">
                                        Contact & Address
                                    </button>
                                </h2>
                                <div id="collapseStep2" class="accordion-collapse collapse" aria-labelledby="headingStep2">
                                    <div class="accordion-body">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label asp-for="PhoneNumber" class="form-label required">Phone Number</label>
                                                <input asp-for="PhoneNumber" class="form-control" placeholder="+880 1XXXXXXXXX" required aria-required="true" />
                                            </div>
                                            <div class="col-md-6">
                                                <label asp-for="Country" class="form-label required">Country</label>
                                                <input asp-for="Country" class="form-control" placeholder="Bangladesh" required aria-required="true" />
                                            </div>
                                            <div class="col-md-6">
                                                <label asp-for="City" class="form-label required">City</label>
                                                <input asp-for="City" class="form-control" placeholder="Dhaka" required aria-required="true" />
                                            </div>
                                            <div class="col-md-6">
                                                <label asp-for="PresentAddress" class="form-label">Present Address</label>
                                                <input asp-for="PresentAddress" class="form-control" placeholder="Street, Area, ZIP" />
                                            </div>
                                            <div class="col-md-6">
                                                <label asp-for="PermanentAddress" class="form-label">Permanent Address</label>
                                                <input asp-for="PermanentAddress" class="form-control" placeholder="Street, Area, ZIP" id="PermanentAddress" />
                                                <div class="form-check mt-1">
                                                    <input class="form-check-input" type="checkbox" value="" id="sameAsPresentAddress">
                                                    <label class="form-check-label" for="sameAsPresentAddress">
                                                        Same as Present Address
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <label asp-for="Nationality" class="form-label">Nationality</label>
                                                <input asp-for="Nationality" class="form-control" placeholder="Bangladeshi" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Step 3: Social & Online Presence -->
                            <div class="accordion-item step-form" data-step="3">
                                <h2 class="accordion-header" id="headingStep3">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseStep3" aria-expanded="false" aria-controls="collapseStep3">
                                        Social & Online Presence
                                    </button>
                                </h2>
                                <div id="collapseStep3" class="accordion-collapse collapse" aria-labelledby="headingStep3">
                                    <div class="accordion-body">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label asp-for="LinkedIn" class="form-label">LinkedIn</label>
                                                <input asp-for="LinkedIn" type="url" class="form-control" placeholder="https://linkedin.com/in/username" />
                                            </div>
                                            <div class="col-md-6">
                                                <label asp-for="GitHub" class="form-label">GitHub</label>
                                                <input asp-for="GitHub" type="url" class="form-control" placeholder="https://github.com/username" />
                                            </div>
                                            <div class="col-md-6">
                                                <label asp-for="Portfolio" class="form-label">Portfolio</label>
                                                <input asp-for="Portfolio" type="url" class="form-control" placeholder="https://myportfolio.com" />
                                            </div>
                                            <div class="col-md-6">
                                                <label asp-for="Website" class="form-label">Website / Blog</label>
                                                <input asp-for="Website" type="url" class="form-control" placeholder="https://example.com" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Step 4: Optional Professional Detail -->
                            <div class="accordion-item step-form" data-step="4">
                                <h2 class="accordion-header" id="headingStep4">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseStep4" aria-expanded="false" aria-controls="collapseStep4">
                                        Optional Professional Detail
                                    </button>
                                </h2>
                                <div id="collapseStep4" class="accordion-collapse collapse" aria-labelledby="headingStep4">
                                    <div class="accordion-body">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label asp-for="ProfilePicture" class="form-label">Profile Picture</label>
                                                <input asp-for="ProfilePicture" type="file" class="form-control" />
                                            </div>
                                            <div class="col-md-6">
                                                <label asp-for="LinkedInHeadline" class="form-label">LinkedIn Headline</label>
                                                <input asp-for="LinkedInHeadline" type="text" class="form-control" placeholder="Software Engineer | Full Stack Developer" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <!-- Navigation Buttons -->
                        <div class="d-flex justify-content-end mt-4">
                            <button type="button" class="btn btn-primary btn-next-step">Save & Continue →</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Info Modal -->
<div class="modal fade" id="infoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="infoModalTitle">Info</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="savedInfoContent">
                ...
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .cv-steps {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .cv-steps .step {
                display: flex;
                align-items: center;
                position: relative;
                padding: 12px 0;
                color: #6c757d;
                font-weight: 500;
                cursor: pointer;
                transition: 0.3s;
            }

                .cv-steps .step .step-circle {
                    width: 28px;
                    height: 28px;
                    border-radius: 50%;
                    border: 2px solid #dee2e6;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    margin-right: 12px;
                    font-size: 14px;
                    transition: 0.3s;
                }

                .cv-steps .step.active {
                    color: #0d6efd;
                    font-weight: 600;
                }

                    .cv-steps .step.active .step-circle {
                        border-color: #0d6efd;
                        background-color: #0d6efd;
                        color: #fff;
                    }

                .cv-steps .step.completed {
                    color: #198754;
                }

                    .cv-steps .step.completed .step-circle {
                        border-color: #198754;
                        background-color: #198754;
                        color: #fff;
                    }

                .cv-steps .step:not(:last-child)::after {
                    content: '';
                    position: absolute;
                    left: 14px;
                    top: 42px;
                    height: 100%;
                    width: 2px;
                    background-color: #e9ecef;
                }

        .accordion-button {
            font-weight: bold;
            background-color: #e7f1ff; 
            color: #0d6efd; 
        }

            .accordion-button:not(.collapsed) {
                background-color: #cfe2ff; 
                color: #0d6efd;
            }

        label.required::after {
            content: " *";
            color: red;
            font-weight: bold;
        }
    </style>
}

@section Scripts {
    <script>
        let currentStep = 1;
        let completedSteps = [];

        function updateSidebar() {
            document.querySelectorAll('.cv-steps .step').forEach((s, index) => {
                const stepNum = index + 1;

                if (completedSteps.includes(stepNum)) {
                    s.classList.add('completed');
                    s.classList.remove('active');
                    s.querySelector('.step-circle').textContent = '✓';
                } else if (stepNum === currentStep) {
                    s.classList.add('active');
                    s.classList.remove('completed');
                    s.querySelector('.step-circle').textContent = stepNum;
                } else {
                    s.classList.remove('active', 'completed');
                    s.querySelector('.step-circle').textContent = stepNum;
                }
            });

            document.getElementById('currentStepDisplay').textContent = currentStep;
        }

        function validateStep(step) {
            const section = document.querySelector(`.step-form[data-step="${step}"]`);
            let valid = true;

            section.querySelectorAll('[required]').forEach(input => {
                if (!input.value) {
                    input.classList.add('is-invalid');
                    valid = false;
                } else {
                    input.classList.remove('is-invalid');
                }
            });

            return valid;
        }

        function buildFormData() {
            const formData = new FormData();

            // Required Fields
            formData.append("FullName", document.querySelector('[name="FullName"]').value);
            formData.append("ProfessionalTitle", document.querySelector('[name="ProfessionalTitle"]').value);
            formData.append("DateOfBirth", document.querySelector('[name="DateOfBirth"]').value);
            formData.append("Gender", document.querySelector('[name="Gender"]')?.value || "");
            formData.append("PhoneNumber", document.querySelector('[name="PhoneNumber"]').value);
            formData.append("Country", document.querySelector('[name="Country"]').value);
            formData.append("City", document.querySelector('[name="City"]').value);

            // Optional Fields
            const optionalFields = ["Religion","PresentAddress","PermanentAddress","Nationality",
                                    "LinkedIn","GitHub","Portfolio","Website","LinkedInHeadline"];
            optionalFields.forEach(f => formData.append(f, document.querySelector(`[name="${f}"]`)?.value || ""));

            // Profile Picture
            const fileInput = document.querySelector('[name="ProfilePicture"]');
            if (fileInput && fileInput.files.length > 0) {
                formData.append("ProfilePicture", fileInput.files[0]);
            }

            return formData;
        }

        async function savePersonalDetail() {
            if (!validateStep(currentStep)) {
                showModal("Error", "Please complete all required fields.", "danger");
                return;
            }

            const formData = buildFormData();

            try {
                const response = await fetch('/CvBuilder/SavePersonalDetail', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (!response.ok || !result.success) {
                    showModal("Error", result.message || "Failed to save data.", "danger");
                    return;
                }

                showModal("Success", formatSavedData(result.data), "success");

                completedSteps.push(currentStep);

                setTimeout(() => window.location.href = '/CvBuilder/Education', 1500);

            } catch (error) {
                console.error(error);
                showModal("Error", "Something went wrong: " + error.message, "danger");
            }
        }

        function formatSavedData(savedData) {
            if (!savedData) return "No data saved.";

            let content = "<ul class='list-group'>";
            for (const key in savedData) {
                if (savedData[key]) {
                    content += `<li class='list-group-item'><strong>${key}:</strong> ${savedData[key]}</li>`;
                }
            }
            content += "</ul>";
            return content;
        }

        function showModal(title, message, type = "info") {
            const modalEl = document.getElementById('infoModal');
            document.getElementById('infoModalTitle').textContent = title;
            const bodyEl = document.getElementById('savedInfoContent');
            bodyEl.innerHTML = message;

            const header = modalEl.querySelector('.modal-header');
            header.className = "modal-header";
            if (type === "success") header.classList.add("bg-success","text-white");
            else if (type === "danger") header.classList.add("bg-danger","text-white");
            else header.classList.add("bg-info","text-white");

            const modal = new bootstrap.Modal(modalEl);
            modal.show();
            setTimeout(() => modal.hide(), 4000);
        }

        document.querySelector('.btn-next-step').addEventListener('click', function(e) {
            e.preventDefault();
            savePersonalDetail();
        });

        updateSidebar();
        // Copy Present Address to Permanent Address
        const presentAddressInput = document.querySelector('[name="PresentAddress"]');
        const permanentAddressInput = document.getElementById('PermanentAddress');
        const sameAddressCheckbox = document.getElementById('sameAsPresentAddress');

        sameAddressCheckbox.addEventListener('change', function() {
            if (this.checked) {
                permanentAddressInput.value = presentAddressInput.value;
                // Optional: disable permanent address field so user cannot edit
                permanentAddressInput.setAttribute('readonly', true);
            } else {
                permanentAddressInput.removeAttribute('readonly');
            }
        });

        // Update Permanent Address dynamically if Present Address changes and checkbox is checked
        presentAddressInput.addEventListener('input', function() {
            if (sameAddressCheckbox.checked) {
                permanentAddressInput.value = presentAddressInput.value;
            }
        });
    </script>
}