@using MYCV.Domain.Enums
@model MYCV.Application.DTOs.UserSummaryObjectiveDto

@{
    ViewData["Title"] = "Summary & Objective";
    var currentStep = (int)CvStep.SummaryObjective;
    var completedSteps = new List<int> { (int)CvStep.PersonalDetail, (int)CvStep.Education, (int)CvStep.Languages };
}

<section class="py-5 bg-light">
    <div class="container">

        <div class="row mb-4">
            <div class="col text-center">
                <h2 class="fw-bold">Summary & Objective</h2>
                <p class="text-muted">Add your professional summary and career objective</p>
            </div>
        </div>

        <div class="row">

            <!-- LEFT STEP NAVIGATION -->
            <div class="col-lg-4 mb-4">
                @await Component.InvokeAsync("CvStepNavigation", new
                    {
                        currentStep = currentStep,
                        completedSteps = completedSteps
                    })
            </div>

            <!-- RIGHT CONTENT -->
            <div class="col-lg-8" style="max-height:80vh; overflow-y:auto;">

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-semibold mb-0">Step <span id="currentStepDisplay">@currentStep</span></h4>
                            <span class="badge bg-primary">In Progress</span>
                        </div>

                        <div class="accordion" id="summaryObjectiveAccordion">

                            <div class="accordion-item step-form" data-step="@currentStep">
                                <h2 class="accordion-header position-relative">

                                    <button class="accordion-button" type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#collapseSummaryObjective">
                                        Summary & Objective
                                    </button>

                                </h2>

                                <div id="collapseSummaryObjective" class="accordion-collapse collapse show">

                                    <div class="accordion-body">

                                        <div class="row g-3">

                                            <div class="col-12">
                                                <label class="form-label required">Summary</label>
                                                <textarea class="form-control summary" rows="4" maxlength="1500"
                                                          placeholder="Write your professional summary"
                                                          required>@Model?.Summary</textarea>
                                            </div>

                                            <div class="col-12">
                                                <label class="form-label required">Objective</label>
                                                <textarea class="form-control objective" rows="3" maxlength="1000"
                                                          placeholder="Write your career objective"
                                                          required>@Model?.Objective</textarea>
                                            </div>

                                        </div>

                                    </div>

                                </div>
                            </div>

                        </div>

                        <!-- BUTTONS -->
                        <div class="d-flex justify-content-between mt-4">

                            <button type="button"
                                    class="btn btn-outline-secondary btn-prev-step">
                                ← Previous
                            </button>

                            <button type="button"
                                    class="btn btn-primary btn-save-summary-objective">
                                Save & Continue →
                            </button>

                        </div>

                    </div>
                </div>

            </div>

        </div>

    </div>
</section>

<!-- Modal -->
<div class="modal fade" id="infoModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="infoModalTitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="savedInfoContent"></div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* === CV Steps === */
        .cv-steps {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .cv-steps .step {
                display: flex;
                align-items: center;
                position: relative;
                padding: 12px 0;
                color: #6c757d;
                font-weight: 500;
                cursor: pointer;
                transition: 0.3s;
            }

                .cv-steps .step .step-circle {
                    width: 28px;
                    height: 28px;
                    border-radius: 50%;
                    border: 2px solid #dee2e6;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    margin-right: 12px;
                    font-size: 14px;
                    transition: 0.3s;
                }

                .cv-steps .step.active {
                    color: #0d6efd;
                    font-weight: 600;
                }

                    .cv-steps .step.active .step-circle {
                        border-color: #0d6efd;
                        background-color: #0d6efd;
                        color: #fff;
                    }

                .cv-steps .step.completed {
                    color: #198754;
                }

                    .cv-steps .step.completed .step-circle {
                        border-color: #198754;
                        background-color: #198754;
                        color: #fff;
                    }

                .cv-steps .step:not(:last-child)::after {
                    content: '';
                    position: absolute;
                    left: 14px;
                    top: 42px;
                    height: 100%;
                    width: 2px;
                    background-color: #e9ecef;
                }

        /* === Accordion === */
        .accordion-button {
            font-weight: bold;
            background-color: #e7f1ff;
            color: #0d6efd;
        }

            .accordion-button:not(.collapsed) {
                background-color: #cfe2ff;
                color: #0d6efd;
            }

        /* === Required Label === */
        label.required::after {
            content: " *";
            color: red;
            font-weight: bold;
        }

        /* === Accordion Body Scroll === */
        .accordion-body {
            max-height: 70vh;
            overflow-y: auto;
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {

            const summaryInput = document.querySelector('.summary');
            const objectiveInput = document.querySelector('.objective');
            const priorityInput = document.querySelector('.priority');

            async function saveSummaryObjective() {
                const data = {
                    Summary: summaryInput.value,
                    Objective: objectiveInput.value,
                    Priority: parseInt(priorityInput?.value) || 1
                };

                const response = await fetch('/CvBuilder/SaveSummaryObjective', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data) // single object now
                });

                const result = await response.json();

                showModal("Saved", result.Message);
            }

            function showModal(title, message) {
                const modalEl = document.getElementById('infoModal');
                document.getElementById('infoModalTitle').textContent = title;
                document.getElementById('savedInfoContent').innerHTML = message;
                const modal = new bootstrap.Modal(modalEl);
                modal.show();
            }

            document.querySelector('.btn-save-summary-objective')
                .addEventListener('click', function(e) {
                    e.preventDefault();
                    saveSummaryObjective();
                });

            document.querySelector('.btn-prev-step')
                .addEventListener('click', function() {
                    window.location.href = '/CvBuilder/Step?stepNumber=' + @((int)CvStep.Languages);
                });

        });
    </script>
}